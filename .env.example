# LLM Configuration (optional — game works without LLM using rule-based fallback)
LLM_API_KEY=
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# Local sGLang server (takes priority over LLM_* if set)
SGLANG_BASE_URL=
SGLANG_MODEL_NAME=

# Storage
DB_PATH=data/wargame.db
LOG_DIR=data/logs
TURN_TIMEOUT_SEC=30
